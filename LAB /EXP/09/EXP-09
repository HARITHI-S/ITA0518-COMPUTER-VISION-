import cv2
from google.colab.patches import cv2_imshow

image = cv2.imread('input_image.png')

if image is None:
    print("Error: Could not load image. Check the file path.")
else:
    clockwise_90 = cv2.rotate(image, cv2.ROTATE_90_CLOCKWISE)

    counter_clockwise_90 = cv2.rotate(image, cv2.ROTATE_90_COUNTERCLOCKWISE)

    cv2.imwrite('rotated_clockwise.png', clockwise_90)
    cv2.imwrite('rotated_counter_clockwise.png', counter_clockwise_90)

    print("Original Image:")
    cv2_imshow(image)
    print("Clockwise (90°):")
    cv2_imshow(clockwise_90)
    print("Counter-Clockwise (90°):")
    cv2_imshow(counter_clockwise_90)
