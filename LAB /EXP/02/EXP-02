import cv2

image = cv2.imread('/content/Picture2.jpg')

if image is None:
    print("Error: Could not load image. Please check the path or if the file exists.")
else:
    blur = cv2.GaussianBlur(image, (5, 5), 10)
    cv2.imwrite('blurred_image.jpg', blur)
    print("Image processed and saved as 'blurred_image.jpg'")
    from google.colab.patches import cv2_imshow
    cv2_imshow(blur)
