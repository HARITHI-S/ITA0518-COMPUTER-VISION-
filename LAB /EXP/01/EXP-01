import cv2
from google.colab.patches import cv2_imshow

img_path = '/content/output_gray_image.jpg'
img = cv2.imread(img_path)
if img is None:
    print(f"Error: Could not load image from {img_path}. Please ensure the image exists and the path is correct.")
else:
    if len(img.shape) == 3:
        gray_img = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
    else:
        gray_img = img 

    cv2_imshow(gray_img)
    cv2.imwrite('gray_image.jpg', gray_img)
    print("Grayscale image displayed and saved as 'gray_image.jpg'")
