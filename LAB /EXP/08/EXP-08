import cv2

img = cv2.imread('image1.jpg')

if img is None:
    print("Error: Could not load image 'image1.jpg'. Please ensure the file exists.")
else:
    height, width = img.shape[:2]
    scale_factor = 2.0
    new_width_large = int(width * scale_factor)
    new_height_large = int(height * scale_factor)

    img_bigger = cv2.resize(
        img,
        (new_width_large, new_height_large),
        interpolation=cv2.INTER_CUBIC
    )

    new_width_small = int(width * 0.5)
    new_height_small = int(height * 0.5)

    img_smaller = cv2.resize(
        img,
        (new_width_small, new_height_small),
        interpolation=cv2.INTER_AREA
    )

    cv2.imwrite('bigger_image1.jpg', img_bigger)
    cv2.imwrite('smaller_image1.jpg', img_smaller)
    print("Images processed and saved: 'bigger_image1.jpg' and 'smaller_image.jpg'")
